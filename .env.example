# ---------------------------------------------------------------------------
# Joe's Garage — environment variables
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Project Settings -> API).
# ---------------------------------------------------------------------------

# The URL of your Supabase project, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "publishable" / anon key (safe to expose in the browser; protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The service-role key (server-only; NEVER expose to the browser).
# Used for admin tasks like inviting staff. Optional for basic operation.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Shop PIN sign-in (optional). Puts a friendly PIN pad in front of the login.
# The PIN just picks which real account to sign in as — the session and Row
# Level Security are unchanged. These are SERVER-ONLY (no NEXT_PUBLIC_ prefix)
# so they never reach the browser. If unset, the app uses email/password.
#
# One account:
# SHOP_PIN=4827
# SHOP_LOGIN_EMAIL=joe@joesgarage.com
# SHOP_LOGIN_PASSWORD=the-real-supabase-password
# SHOP_LOGIN_NAME=Joe
#
# Or per-person (keeps correct "logged by" attribution) as a JSON array:
# SHOP_PINS=[{"name":"Joe","pin":"4827","email":"joe@joesgarage.com","password":"…"},{"name":"Cami","pin":"1590","email":"cami@joesgarage.com","password":"…"}]
#
# Tip: create the account(s) once via the "Staff sign-in" email/password screen,
# then put their credentials here. Use a 6-digit PIN for better security.
