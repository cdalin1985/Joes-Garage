# ---------------------------------------------------------------------------
# Joe's Garage — environment variables
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Project Settings -> API).
# ---------------------------------------------------------------------------

# The URL of your Supabase project, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "publishable" / anon key (safe to expose in the browser; protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The service-role key (server-only; NEVER expose to the browser).
# Used for admin tasks like inviting staff. Optional for basic operation.
SUPABASE_SERVICE_ROLE_KEY=
